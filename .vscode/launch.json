{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Lektorat starten",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/server.js",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "restart": true,
      "runtimeArgs": ["--watch"],
      "skipFiles": ["<node_internals>/**", "${workspaceFolder}/node_modules/**"]
    }
  ]
}
