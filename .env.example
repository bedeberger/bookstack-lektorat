# BookStack-Instanz
BOOKSTACK_URL=http://<host>:80

# BookStack API Token
TOKEN_ID=
TOKEN_KENNWORT=

# Port des lokalen Dev-Servers (Standard: 3737)
# PORT=3737

# ── KI-Provider ──────────────────────────────────────────────────────────────
# Welcher Provider verwendet wird: 'claude' (Standard) oder 'ollama'
# API_PROVIDER=claude

# ── Claude (Anthropic) ───────────────────────────────────────────────────────
# Nur nötig wenn API_PROVIDER=claude (oder nicht gesetzt)
ANTHROPIC_API_KEY=sk-ant-...

# Claude-Modell (Standard: claude-sonnet-4-6)
# Optionen: claude-opus-4-6, claude-haiku-4-5-20251001
# MODEL_NAME=claude-sonnet-4-6

# Maximale Output-Tokens für Claude-Aufrufe (Standard: 64000)
# MODEL_TOKEN=64000

# ── Ollama (lokal) ───────────────────────────────────────────────────────────
# Nur nötig wenn API_PROVIDER=ollama
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.2

