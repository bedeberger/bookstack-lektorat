# BookStack-Instanz 
BOOKSTACK_URL=http://<host>:80

# Anthropic API Key (für den Claude-Proxy im Server)
ANTHROPIC_API_KEY=sk-ant-...

# BookStack API Token
TOKEN_ID=
TOKEN_KENNWORT=

# Port des lokalen Dev-Servers (Standard: 3737)
# PORT=3737

# Maximale Output-Tokens für KI-Aufrufe (Standard: 64000)
# MODEL_TOKEN=64000

# KI-Modell (Standard: claude-sonnet-4-6)
# Für Anthropic-Modelle z.B.: claude-opus-4-6, claude-haiku-4-5-20251001
# MODEL_NAME=claude-sonnet-4-6
