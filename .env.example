# BookStack-Instanz (LXC oder lokal)
BOOKSTACK_URL=http://<lxc-ip>:80

# Anthropic API Key (für den Claude-Proxy im Server)
ANTHROPIC_API_KEY=sk-ant-...

# BookStack API Token (optional – alternativ manuell im Browser eingeben)
TOKEN_ID=
TOKEN_KENNWORT=

# Port des lokalen Dev-Servers (Standard: 3737)
# PORT=3737
